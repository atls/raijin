{
  "name": "tools",
  "private": true,
  "type": "module",
  "workspaces": [
    "schematics/**/*",
    "prettier/**/*",
    "code/**/*",
    "webpack/**/*",
    "config/**/*",
    "yarn/**/*",
    "cli/**/*"
  ],
  "scripts": {
    "cli:build": "yarn workspace @atls/yarn-cli build",
    "raijin:check": "yarn raijin:check:drift && yarn raijin:check:localization && yarn raijin:smoke:deterministic && yarn raijin:smoke:schematic",
    "raijin:check:drift": "node scripts/raijin/generate-artifacts.mjs && git diff --exit-code -- README.md README_EN.md docs/README.md docs/README.ru.md docs/raijin && test -z \"$(git ls-files --others --exclude-standard -- README.md README_EN.md docs/README.md docs/README.ru.md docs/raijin)\"",
    "raijin:check:localization": "node scripts/raijin/check-localization-sync.mjs",
    "raijin:generate": "node scripts/raijin/generate-artifacts.mjs",
    "raijin:smoke:deterministic": "node scripts/raijin/run-deterministic-smoke.mjs",
    "raijin:smoke:schematic": "yarn workspace @atls/code-schematics smoke:schematic",
    "schematic:test": "yarn raijin:smoke:schematic",
    "yarn:download": "yarn workspace @atls/yarn-plugin-pnp-patch yarn:download"
  },
  "resolutions": {
    "@yarnpkg/builder": "https://github.com/TorinAsakura/yarnpkg-builder.git#commit=05a30e58225e52c7fa61664aa939f1fd7fedb7b6",
    "clipanion": "4.0.0-rc.2",
    "eslint": "9.14.0",
    "flatted@npm:^3.2.7": "patch:flatted@npm%3A3.2.7#./.yarn/patches/flatted-npm-3.2.7-0da10b7c56.patch",
    "ink": "3",
    "jsonc-parser@npm:3.3.1": "patch:jsonc-parser@npm%3A3.3.1#~/.yarn/patches/jsonc-parser-npm-3.3.1-f57c3cdcf5.patch",
    "sort-package-json@2.4.1": "patch:sort-package-json@npm%3A2.4.1#./.yarn/patches/sort-package-json-npm-2.4.1-8ff012947f.patch",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@atls/raijin": "workspace:*",
    "@types/node": "24.12.2",
    "@yarnpkg/builder": "https://github.com/TorinAsakura/yarnpkg-builder.git#commit=05a30e58225e52c7fa61664aa939f1fd7fedb7b6",
    "esbuild": "npm:esbuild-wasm@^0.23.1",
    "prettier": "3.5.3",
    "react": "18.3.1",
    "typescript": "5.9.3"
  },
  "packageManager": "yarn@4.14.1",
  "formatterIgnorePatterns": [
    "CHANGELOG.md"
  ],
  "typecheckSkipLibCheck": true
}
