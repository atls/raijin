        "default": "./dist/runtime/ts-node-register.js"
      },
      "./ts-ext-register": {
        "import": "./dist/runtime/ts-ext-register.js",
        "types": "./dist/runtime/ts-ext-register.d.ts",
        "default": "./dist/runtime/ts-ext-register.js"
      },
      "./prettier": {
        "import": "./dist/runtime/prettier/index.js",
        "types": "./dist/runtime/prettier/index.d.ts",
        "default": "./dist/runtime/prettier/index.js"
      },
      "./prettier/config": {
        "import": "./dist/runtime/prettier/config.js",
        "types": "./dist/runtime/prettier/config.d.ts",
        "default": "./dist/runtime/prettier/config.js"
      },
      "./prettier-plugin": {
        "import": "./dist/runtime/prettier/plugin/index.js",
        "types": "./dist/runtime/prettier/plugin/index.d.ts",
        "default": "./dist/runtime/prettier/plugin/index.js"
      },
      "./typescript-config": {
        "import": "./dist/runtime/typescript-config.js",
        "types": "./dist/runtime/typescript-config.d.ts",
        "default": "./dist/runtime/typescript-config.js"
      }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "schematics": "./dist/generation/project/collection/collection.json",
  "typecheckSkipLibCheck": true
}
