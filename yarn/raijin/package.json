{
  "name": "@atls/raijin",
  "version": "0.6.4",
  "description": "Public Raijin initializer and runtime package",
  "homepage": "https://github.com/atls/raijin#readme",
  "bugs": {
    "url": "https://github.com/atls/raijin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atls/raijin.git",
    "directory": "yarn/raijin"
  },
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./application/generation": "./src/application/generation/index.ts",
    "./commands": "./src/commands/index.ts",
    "./config": "./src/config/index.ts",
    "./config/eslint": "./src/config/eslint/index.ts",
    "./config/next": "./src/config/next/index.ts",
    "./config/prettier": "./src/config/prettier/index.ts",
    "./config/sync": "./src/config/sync/index.ts",
    "./config/typescript": {
      "raijin-project-collection-build": "./dist/config/typescript/index.js",
      "default": "./src/config/typescript/index.ts"
    },
    "./filesystem": "./src/filesystem/index.ts",
    "./infrastructure/generation": "./src/infrastructure/generation/index.ts",
    "./project": "./src/project/index.ts",
    "./yarn": "./src/yarn/index.ts",
    "./runtime": "./src/runtime.ts",
    "./runtime/node/bootstrap": "./src/runtime/node/bootstrap/index.ts",
    "./types": "./types/index.d.ts",
    "./eslint": "./src/runtime/eslint.ts",
    "./webpack": "./src/runtime/webpack.ts",
    "./webpack-proto-imports-loader": "./src/runtime/webpack/proto-imports.loader.ts",
    "./typescript": "./src/runtime/typescript.ts",
    "./runtime-exec-argv": "./src/runtime/runtime-exec-argv.ts",
    "./runtime-resolver": "./src/runtime/runtime-resolver.ts",
    "./typescript-loader": "./src/runtime/typescript-loader.ts",
    "./svgr": "./src/runtime/svgr.ts",
    "./ts-node-register": "./src/runtime/ts-node-register.ts",
    "./ts-ext-register": "./src/runtime/ts-ext-register.ts",
    "./prettier": "./src/runtime/prettier/index.ts",
    "./prettier/config": "./src/runtime/prettier/config.ts",
    "./prettier-plugin": "./src/runtime/prettier/plugin/index.ts",
    "./typescript-config": "./src/runtime/typescript-config.ts"
  },
  "main": "src/index.ts",
  "bin": "./bin/raijin.mjs",
  "files": [
    "bin",
    "dist",
    "types"
  ],
  "scripts": {
    "build": "yarn run build:generation",
    "build:generation": "yarn run build:library && node --require ../../.pnp.cjs --loader ../../.pnp.loader.mjs --loader ./dist/runtime/typescript-loader.js ./scripts/generation/project/build.ts",
    "build:library": "yarn library build",
    "prepack": "yarn run build",
    "postpack": "rm -rf dist"
  },
  "dependencies": {
    "@angular-devkit/core": "19.1.5",
    "@angular-devkit/schematics": "19.1.5",
    "@babel/types": "7.25.6",
    "@next/eslint-plugin-next": "16.0.7",
    "@svgr/core": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@typescript-eslint/eslint-plugin": "8.48.1",
    "@typescript-eslint/parser": "8.48.1",
    "eslint": "9.22.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-n": "17.23.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-security": "3.0.1",
    "fast-glob": "3.3.2",
    "import-sort": "6.0.0",
    "import-sort-parser": "6.0.0",
    "import-sort-parser-typescript": "6.0.0",
    "import-sort-style": "6.0.0",
    "node-loader": "2.1.0",
    "prettier": "3.5.3",
    "protocol-buffers-schema": "3.6.0",
    "react": "18.3.1",
    "rxjs": "7.8.1",
    "sort-package-json": "2.4.1",
    "strip-json-comments": "3.1.1",
    "ts-loader": "9.5.2",
    "typescript": "5.9.3",
    "webpack": "5.98.0",
    "zod": "4.1.13",
    "zod-validation-error": "4.0.2"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@types/protocol-buffers-schema": "3.4.3",
    "@yarnpkg/cli": "4.14.1",
    "@yarnpkg/core": "4.7.0",
    "@yarnpkg/esbuild-plugin-pnp": "3.0.0-rc.15",
    "@yarnpkg/fslib": "3.1.5",
    "esbuild": "0.24.2"
  },
  "peerDependencies": {
    "@yarnpkg/core": "*",
    "@yarnpkg/fslib": "*"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "raijin": "./bin/raijin.mjs"
    },
    "exports": {
      "./package.json": "./package.json",
      "./types": "./types/index.d.ts",
      "./application/generation": {
        "import": "./dist/application/generation/index.js",
        "types": "./dist/application/generation/index.d.ts",
        "default": "./dist/application/generation/index.js"
      },
      "./commands": {
        "import": "./dist/commands/index.js",
        "types": "./dist/commands/index.d.ts",
        "default": "./dist/commands/index.js"
      },
      "./config": {
        "import": "./dist/config/index.js",
        "types": "./dist/config/index.d.ts",
        "default": "./dist/config/index.js"
      },
      "./config/eslint": {
        "import": "./dist/config/eslint/index.js",
        "types": "./dist/config/eslint/index.d.ts",
        "default": "./dist/config/eslint/index.js"
      },
      "./config/next": {
        "import": "./dist/config/next/index.js",
        "types": "./dist/config/next/index.d.ts",
        "default": "./dist/config/next/index.js"
      },
      "./config/prettier": {
        "import": "./dist/config/prettier/index.js",
        "types": "./dist/config/prettier/index.d.ts",
        "default": "./dist/config/prettier/index.js"
      },
      "./config/sync": {
        "import": "./dist/config/sync/index.js",
        "types": "./dist/config/sync/index.d.ts",
        "default": "./dist/config/sync/index.js"
      },
      "./config/typescript": {
        "import": "./dist/config/typescript/index.js",
        "types": "./dist/config/typescript/index.d.ts",
        "default": "./dist/config/typescript/index.js"
      },
      "./filesystem": {
        "import": "./dist/filesystem/index.js",
        "types": "./dist/filesystem/index.d.ts",
        "default": "./dist/filesystem/index.js"
      },
      "./infrastructure/generation": {
        "import": "./dist/infrastructure/generation/index.js",
        "types": "./dist/infrastructure/generation/index.d.ts",
        "default": "./dist/infrastructure/generation/index.js"
      },
      "./project": {
        "import": "./dist/project/index.js",
        "types": "./dist/project/index.d.ts",
        "default": "./dist/project/index.js"
      },
      "./yarn": {
        "import": "./dist/yarn/index.js",
        "types": "./dist/yarn/index.d.ts",
        "default": "./dist/yarn/index.js"
      },
      "./runtime": {
        "import": "./dist/runtime.js",
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "./runtime/node/bootstrap": {
        "import": "./dist/runtime/node/bootstrap/index.js",
        "types": "./dist/runtime/node/bootstrap/index.d.ts",
        "default": "./dist/runtime/node/bootstrap/index.js"
      },
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./eslint": {
        "import": "./dist/runtime/eslint.js",
        "types": "./dist/runtime/eslint.d.ts",
        "default": "./dist/runtime/eslint.js"
      },
      "./webpack": {
        "import": "./dist/runtime/webpack.js",
        "types": "./dist/runtime/webpack.d.ts",
        "default": "./dist/runtime/webpack.js"
      },
      "./webpack-proto-imports-loader": {
        "import": "./dist/runtime/webpack/proto-imports.loader.js",
        "types": "./dist/runtime/webpack/proto-imports.loader.d.ts",
        "default": "./dist/runtime/webpack/proto-imports.loader.js"
      },
      "./typescript": {
        "import": "./dist/runtime/typescript.js",
        "types": "./dist/runtime/typescript.d.ts",
        "default": "./dist/runtime/typescript.js"
      },
      "./runtime-exec-argv": {
        "import": "./dist/runtime/runtime-exec-argv.js",
        "types": "./dist/runtime/runtime-exec-argv.d.ts",
        "default": "./dist/runtime/runtime-exec-argv.js"
      },
      "./runtime-resolver": {
        "import": "./dist/runtime/runtime-resolver.js",
        "types": "./dist/runtime/runtime-resolver.d.ts",
        "default": "./dist/runtime/runtime-resolver.js"
      },
      "./typescript-loader": {
        "import": "./dist/runtime/typescript-loader.js",
        "types": "./dist/runtime/typescript-loader.d.ts",
        "default": "./dist/runtime/typescript-loader.js"
      },
      "./svgr": {
