{
  "name": "@atls/yarn-plugin-library",
  "version": "1.0.30",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./sources/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "builder build plugin --external-file ../builder/externals.json",
    "prepack": "yarn run build",
    "postpack": "rm -rf dist"
  },
  "dependencies": {
    "@atls/cli-ui-error-info-component": "workspace:*",
    "@atls/cli-ui-log-record-component": "workspace:*",
    "@atls/cli-ui-pretty-logs-component": "workspace:*",
    "@atls/cli-ui-renderer-static-component": "workspace:*",
    "@atls/cli-ui-typescript-diagnostic-component": "workspace:*",
    "@atls/cli-ui-typescript-progress-component": "workspace:*",
    "@atls/code-typescript": "workspace:*",
    "@atls/raijin": "workspace:*",
    "clipanion": "4.0.0-rc.2",
    "ink": "3.2.0",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.18",
    "@yarnpkg/builder": "4.2.0",
    "@yarnpkg/cli": "4.14.1",
    "@yarnpkg/core": "4.7.0",
    "@yarnpkg/fslib": "3.1.5"
  },
  "peerDependencies": {
    "@yarnpkg/cli": "*",
    "@yarnpkg/core": "*"
  },
  "raijin": {
    "pack": {
      "exports": {
        "./package.json": "./package.json",
        ".": {
          "import": "./dist/index.js",
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "main": "dist/index.js",
      "types": "dist/index.d.ts"
    }
  }
}
